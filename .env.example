# Copy this file to .env and fill in your own Firebase project's
# values (Firebase Console -> Project Settings -> Your apps -> Web app).
#
# NOTE: This project ships as plain static files with no build step,
# so these values are NOT automatically read from .env by the
# browser. They exist here as documentation / for use if you wire up
# a small build step (Vite, esbuild, etc.) that injects them into
# window.__FIREBASE_CONFIG__ before js/firebase-config.js runs.
# Until then, edit the fallback object directly in js/firebase-config.js.
#
# These are Firebase *client* identifiers, not secret keys - see
# https://firebase.google.com/docs/projects/api-keys - real access
# control comes from database.rules.json, not from hiding these.

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
